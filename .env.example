################################
# URLs dos servidores externos #
################################

# Suporta http:// e https:// — use o que o seu servidor usa
TAIGA_URL=http://IP_OU_HOSTNAME_TAIGA/api/v1
TAIGA_WEB_URL=http://IP_OU_HOSTNAME_TAIGA
TAIGA_USERNAME=usuario_taiga
TAIGA_PASSWORD=senha_taiga

GLPI_URL=http://IP_OU_HOSTNAME_GLPI/apirest.php
GLPI_APP_TOKEN=app_token_aqui
GLPI_USER_TOKEN=user_token_aqui

#######
# SSL #
#######

# false (padrão) → verifica certificado normalmente
# true           → aceita qualquer certificado, inclusive autoassinados
#                  Use apenas se não puder montar o certificado em ./certs/
SSL_SKIP_VERIFY=false

##########################
# Segurança dos webhooks #
##########################

# IPs autorizados a chamar /api/webhook/*
# Deixe comentado (ou use * no application.yaml) para liberar todos
#WEBHOOK_ALLOWED_IP_GLPI=IP_DO_SERVIDOR_GLPI
#WEBHOOK_ALLOWED_IP_TAIGA=IP_DO_SERVIDOR_TAIGA
